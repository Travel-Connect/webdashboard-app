# ------------------------------------------------------------------
# webdashboard-app environment variables (EXAMPLE / dummy values)
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# Do NOT prefix secrets with NEXT_PUBLIC_ (that exposes them to the browser).
# ------------------------------------------------------------------

# Supabase project (browser-safe; RLS is the security boundary)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Server-only secret. Used ONLY by import commit / mart refresh / seed jobs.
# Must never reach the browser. No NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Dashboard data source switch (server): "mock" | "live"
DASHBOARD_DATA_SOURCE=mock

# Client-side mock switch for the fetcher (when MSW is not used)
NEXT_PUBLIC_USE_MOCK=true
